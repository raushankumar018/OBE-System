{
  "info": {
    "name": "OBE AI System API",
    "description": "Complete CO-PO-PSO Mapping & Attainment API — Vignan's University",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",   "value": "http://localhost:8000" },
    { "key": "session_id", "value": "PASTE_SESSION_ID_HERE" },
    { "key": "course_code","value": "22CS808" },
    { "key": "academic_year","value": "2025-26" }
  ],
  "item": [
    {
      "name": "0. Health Check",
      "request": {
        "method": "GET",
        "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] }
      }
    },
    {
      "name": "STEP 1 — Generate COs (file upload)",
      "request": {
        "method": "POST",
        "url": { "raw": "{{base_url}}/co/generate", "host": ["{{base_url}}"], "path": ["co","generate"] },
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "file",          "type": "file",  "src": "ML_Syllabus.pdf",
              "description": "Upload your syllabus PDF/DOCX/TXT" },
            { "key": "course_code",   "value": "22CS808",                         "type": "text" },
            { "key": "course_name",   "value": "Machine Learning",                "type": "text" },
            { "key": "university",    "value": "Vignan's University",             "type": "text" },
            { "key": "department",    "value": "Computer Science and Engineering","type": "text" },
            { "key": "degree",        "value": "B.Tech",                          "type": "text" },
            { "key": "academic_year", "value": "2025-26",                         "type": "text" },
            { "key": "semester",      "value": "III",                             "type": "text" },
            { "key": "coordinator",   "value": "Dr. A. B. Sharma",               "type": "text" },
            { "key": "num_students",  "value": "60",                              "type": "text" },
            { "key": "num_cos_target","value": "4",                               "type": "text" },
            { "key": "num_modules",   "value": "2",                               "type": "text" }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "if (json.session_id) {",
              "  pm.collectionVariables.set('session_id', json.session_id);",
              "  console.log('session_id saved:', json.session_id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "STEP 1b — Generate COs (text input)",
      "request": {
        "method": "POST",
        "url": { "raw": "{{base_url}}/co/generate", "host": ["{{base_url}}"], "path": ["co","generate"] },
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "syllabus_text", "type": "text",
              "value": "UNIT 1: INTRODUCTION Machine learning applications, types of learning...\nUNIT 2: FEATURE SELECTION Filter methods, wrapper methods, PCA, LDA...\nUNIT 3: CLASSIFICATION SVM, Decision Trees, Ensemble methods...\nUNIT 4: CLUSTERING K-means, DBSCAN, Hierarchical clustering..." },
            { "key": "course_code",   "value": "22CS808",         "type": "text" },
            { "key": "course_name",   "value": "Machine Learning", "type": "text" },
            { "key": "num_cos_target","value": "4",                "type": "text" }
          ]
        }
      }
    },
    {
      "name": "STEP 2a — Feedback: Satisfied (confirm COs)",
      "request": {
        "method": "POST",
        "url": { "raw": "{{base_url}}/co/feedback", "host": ["{{base_url}}"], "path": ["co","feedback"] },
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"session_id\": \"{{session_id}}\",\n  \"satisfied\": true\n}"
        }
      }
    },
    {
      "name": "STEP 2b — Feedback: Not satisfied (give feedback to regenerate)",
      "request": {
        "method": "POST",
        "url": { "raw": "{{base_url}}/co/feedback", "host": ["{{base_url}}"], "path": ["co","feedback"] },
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"session_id\": \"{{session_id}}\",\n  \"satisfied\": false,\n  \"feedback\": \"CO3 should focus on clustering algorithms not classification. CO1 needs to mention data preprocessing. Make the COs more specific to the course topics.\"\n}"
        }
      }
    },
    {
      "name": "STEP 2c — Provide own COs (fallback)",
      "request": {
        "method": "POST",
        "url": { "raw": "{{base_url}}/co/feedback", "host": ["{{base_url}}"], "path": ["co","feedback"] },
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"session_id\": \"{{session_id}}\",\n  \"satisfied\": false,\n  \"user_provided_cos\": [\n    {\n      \"co_id\": \"CO1\",\n      \"co_text\": \"Apply machine learning models to solve real-world prediction problems using various learning algorithms.\",\n      \"bloom_level\": \"Apply\",\n      \"po_mapping\": [\"PO1\", \"PO2\"],\n      \"pso_mapping\": [\"PSO1\"]\n    },\n    {\n      \"co_id\": \"CO2\",\n      \"co_text\": \"Analyze feature selection and dimensionality reduction techniques to improve model performance.\",\n      \"bloom_level\": \"Analyze\",\n      \"po_mapping\": [\"PO2\", \"PO5\"],\n      \"pso_mapping\": [\"PSO1\", \"PSO2\"]\n    },\n    {\n      \"co_id\": \"CO3\",\n      \"co_text\": \"Evaluate various classification and ensemble learning methods for complex pattern recognition problems.\",\n      \"bloom_level\": \"Evaluate\",\n      \"po_mapping\": [\"PO2\", \"PO4\"],\n      \"pso_mapping\": [\"PSO1\"]\n    },\n    {\n      \"co_id\": \"CO4\",\n      \"co_text\": \"Design and implement clustering models using advanced machine learning tools for data analysis.\",\n      \"bloom_level\": \"Create\",\n      \"po_mapping\": [\"PO3\", \"PO5\"],\n      \"pso_mapping\": [\"PSO2\"]\n    }\n  ]\n}"
        }
      }
    },
    {
      "name": "STEP 2d — Explicit Confirm (alternative to feedback satisfied=true)",
      "request": {
        "method": "POST",
        "url": { "raw": "{{base_url}}/co/confirm", "host": ["{{base_url}}"], "path": ["co","confirm"] },
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"session_id\": \"{{session_id}}\"\n}"
        }
      }
    },
    {
      "name": "Get Session State",
      "request": {
        "method": "GET",
        "url": { "raw": "{{base_url}}/co/session/{{session_id}}", "host": ["{{base_url}}"], "path": ["co","session","{{session_id}}"] }
      }
    },
    {
      "name": "STEP 3 — Generate CO-PO-PSO Mapping",
      "request": {
        "method": "POST",
        "url": { "raw": "{{base_url}}/mapping/generate", "host": ["{{base_url}}"], "path": ["mapping","generate"] },
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"session_id\": \"{{session_id}}\"\n}"
        }
      }
    },
    {
      "name": "Get Mapping (retrieve existing)",
      "request": {
        "method": "GET",
        "url": { "raw": "{{base_url}}/mapping/{{session_id}}", "host": ["{{base_url}}"], "path": ["mapping","{{session_id}}"] }
      }
    },
    {
      "name": "STEP 4 — Download Marks Template",
      "request": {
        "method": "GET",
        "url": { "raw": "{{base_url}}/template/marks/{{session_id}}", "host": ["{{base_url}}"], "path": ["template","marks","{{session_id}}"] }
      }
    },
    {
      "name": "STEP 5 — Calculate Attainment (with marks file)",
      "request": {
        "method": "POST",
        "url": { "raw": "{{base_url}}/attainment/calculate", "host": ["{{base_url}}"], "path": ["attainment","calculate"] },
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "session_id",     "value": "{{session_id}}", "type": "text" },
            { "key": "marks_file",     "type": "file", "src": "marks_filled.xlsx",
              "description": "Upload filled marks template. Leave empty for demo simulation." },
            { "key": "indirect_score", "value": "3.5", "type": "text",
              "description": "Course Exit Survey average (0-5)" }
          ]
        }
      }
    },
    {
      "name": "STEP 5b — Calculate Attainment (simulation / no file)",
      "request": {
        "method": "POST",
        "url": { "raw": "{{base_url}}/attainment/calculate", "host": ["{{base_url}}"], "path": ["attainment","calculate"] },
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "session_id",     "value": "{{session_id}}", "type": "text" },
            { "key": "indirect_score", "value": "3.0",            "type": "text" }
          ]
        }
      }
    },
    {
      "name": "STEP 6a — Download PDF Report",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/attainment/download/pdf/{{course_code}}/{{academic_year}}",
          "host": ["{{base_url}}"],
          "path": ["attainment","download","pdf","{{course_code}}","{{academic_year}}"]
        }
      }
    },
    {
      "name": "STEP 6b — Download Excel Report",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/attainment/download/excel/{{course_code}}/{{academic_year}}",
          "host": ["{{base_url}}"],
          "path": ["attainment","download","excel","{{course_code}}","{{academic_year}}"]
        }
      }
    },
    {
      "name": "List All Attainment History",
      "request": {
        "method": "GET",
        "url": { "raw": "{{base_url}}/attainment/history", "host": ["{{base_url}}"], "path": ["attainment","history"] }
      }
    },
    {
      "name": "Get Attainment JSON (from DB)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/attainment/{{course_code}}/{{academic_year}}",
          "host": ["{{base_url}}"],
          "path": ["attainment","{{course_code}}","{{academic_year}}"]
        }
      }
    }
  ]
}
